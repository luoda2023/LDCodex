UPSTREAM_TIMEOUT_MS=120000

# Dynamic concurrency - 2核VPS，要留余量给其他程序
# 2核CPU + 1.6G内存，还要跑 MySQL、Docker、1Panel
# 并发太高会 CPU 打满 + 内存撑爆 → VPS 卡死
# 安全值：max=6 留给 bridge，实测每个请求约 80MB RSS
# 6个并发 = 480MB，加上 Node 基础 ~80MB ≈ 560MB，留 200MB 余量
DYN_LIMIT_MIN=2
DYN_LIMIT_MAX=6
DYN_TARGET_LATENCY=15000
DYN_TUNE_INTERVAL=10000

# Ports
PROXY_PORT=40000
CONFIG_PORT=40001
ADMIN_PORT=40002
